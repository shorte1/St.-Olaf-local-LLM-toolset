# Copy this file to .env and fill in your values before running setup.sh
# Generate SECRET_KEY with: python3 -c "import secrets; print(secrets.token_hex(24))"
# Generate ADMIN_KEY with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"

SECRET_KEY=replace-with-generated-secret-key
ADMIN_KEY=replace-with-generated-admin-key
